{
  "expo": {
    "name": "War Empire",
    "slug": "war-empire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "war-empire",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thomascunin.warempire"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e17"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.thomascunin.warempire"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ]
  }
}
